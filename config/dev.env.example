# Copy to config/dev.env.local or source manually for local development.
# Do not commit real tokens.

# Safe defaults; keep local unless you intentionally review the security model.
LULO_OPENCLAW_HTTP_BASE_URL=http://127.0.0.1:18789
LULO_OPENCLAW_WS_URL=ws://127.0.0.1:18789

# Optional bearer token. Prefer macOS Keychain once the bridge contract stabilizes.
# LULO_OPENCLAW_TOKEN=replace-with-local-token

# Optional routing metadata.
LULO_OPENCLAW_SESSION=agent:main:clippy:local
LULO_OPENCLAW_AGENT=openclaw/default
# LULO_OPENCLAW_MODEL=openai/gpt-5.5

# Required to send actual HTTP requests. Default scripts use false.
LULO_OPENCLAW_ENABLE_POST=false

# If the Swift app source moves, point scripts at it.
# LULO_CLIPPY_SOURCE_DIR=/Users/pinchy/.openclaw/workspace/lulo-clippy
